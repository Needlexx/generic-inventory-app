{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "inventory-app",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-c", "import os,http.server,socketserver; PORT=int(os.environ.get('PORT','8000')); socketserver.TCPServer(('',PORT), http.server.SimpleHTTPRequestHandler).serve_forever()"],
      "autoPort": true
    }
  ]
}
